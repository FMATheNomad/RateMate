{
  "manifest_version": 3,
  "name": "RateMate - Dynamic Currency Converter",
  "description": "Automatically convert e-commerce prices to your local currency with real-time exchange rates.",
  "version": "2.0",
  "permissions": ["storage"],
  "host_permissions": ["https://api.frankfurter.app/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
